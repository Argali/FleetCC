# Copy this file to .env and fill in real values — never commit .env to git

JWT_SECRET=change_this_to_a_long_random_string
GPS_PROVIDER=mock
PORT=3001

# ── ERP Integration ───────────────────────────────────────────────────────────
# ERP_SOURCE controls where vehicle/operator/maintenance data comes from.
#   mock         → in-memory mock data (default, safe for development)
#   targetcross  → live connector ingestion (requires XML access)
ERP_SOURCE=mock

# How often to re-ingest from the ERP (milliseconds). Default: 5 minutes.
# INGEST_INTERVAL_MS=300000

# Target Cross connector settings (only used when ERP_SOURCE=targetcross)
# TARGETCROSS_XML_PATH=/path/to/export.xml      ← local file drop
# TARGETCROSS_ORG_ID=cauto                      ← tenant slug
# TARGETCROSS_CONFIG_PATH=                      ← override mapping config (optional)

# URL of the deployed frontend (for CORS)
# FRONTEND_URL=https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Valhalla routing engine (use public instance or self-hosted)
VALHALLA_URL=https://valhalla1.openstreetmap.de

# Seed user credentials — override all of these before deploying
SEED_SUPERADMIN_EMAIL=superadmin@fleetcc.dev
SEED_SUPERADMIN_PASSWORD=change_me_superadmin

SEED_FM1_NAME=Fleet Manager 1
SEED_FM1_EMAIL=fm1@cauto.it

SEED_FM2_NAME=Fleet Manager 2
SEED_FM2_EMAIL=fm2@cauto.it

SEED_OFFICINA_EMAIL=officina@cauto.it
SEED_OFFICINA_PASSWORD=change_me_officina

SEED_ADMIN_EMAIL=admin@cauto.it
SEED_ADMIN_PASSWORD=change_me_admin
